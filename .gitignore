# Generated by /genesis or by daily use
.claude/memory-hot.md
.claude/memory-hot.*.md

# Database (operational data — NEVER commit)
Database/team.db
Database/team.db-shm
Database/team.db-wal
Database/*.db-journal

# MemPalace data (user's memory — NEVER commit)
.mempalace/
~/.mempalace/

# User-generated agents and profiles (created by /genesis or /hire)
# Edit this list if you want to commit your own agents to a private fork
.claude/agents/*
!.claude/agents/maria.md
!.claude/agents/sarah.md
!.claude/agents/lena.md
!.claude/agents/.gitkeep
Team/*
!Team/.gitkeep

# Inbox content
Owners Inbox/*
Team Inbox/*
!Owners Inbox/.gitkeep
!Team Inbox/.gitkeep

# Environment / secrets
.env
.env.local
.env.*.local
*.token
*.key

# Python
__pycache__/
*.py[cod]
*.egg-info/
.venv/
venv/
.pytest_cache/

# Editors / OS
.DS_Store
.idea/
.vscode/
*.swp
*.swo
*~

# Build / cache
node_modules/
.cache/
dist/
build/

# Logs
*.log
logs/
